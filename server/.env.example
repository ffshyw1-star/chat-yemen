# ==========================
# Chat Yemen Configuration
# ==========================

# تشغيل التطبيق
NODE_ENV=development

# المنفذ
PORT=3000

# ==========================
# JWT
# ==========================

JWT_SECRET=CHANGE_THIS_SECRET_TO_A_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ==========================
# Database
# ==========================

DB_PATH=./database/chat.db

# ==========================
# Uploads
# ==========================

UPLOAD_PATH=./uploads

MAX_FILE_SIZE=5242880

# ==========================
# Website
# ==========================

SITE_NAME=شات اليمن المطور

SITE_URL=http://localhost:3000

DEFAULT_ROOM=1

# ==========================
# Security
# ==========================

RATE_LIMIT_WINDOW=15

RATE_LIMIT_MAX=100

# ==========================
# Socket.IO
# ==========================

SOCKET_CORS=*

# ==========================
# Logging
# ==========================

LOG_LEVEL=info